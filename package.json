{
  "name": "minecraft-server-manager",
  "version": "1.0.0",
  "description": "REST API for remote Minecraft server management.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn src/server.ts",
    "lint": "eslint src/ --ext .ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "express": "^4.19.2",
    "@prisma/client": "^5.15.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "zod": "^3.23.8",
    "winston": "^3.13.0",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.3.1",
    "child_process": "^1.0.2"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.2",
    "prisma": "^5.15.0",
    "ts-node-dev": "^2.0.0",
    "eslint": "^9.5.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "M4trixDev"
}
